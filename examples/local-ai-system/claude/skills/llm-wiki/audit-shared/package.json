{
  "name": "audit-shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared audit schema, anchor algorithm, id generator, and YAML serializer for the LLM Wiki Obsidian plugin and web viewer.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist",
    "test": "node --test dist/*.test.js"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
